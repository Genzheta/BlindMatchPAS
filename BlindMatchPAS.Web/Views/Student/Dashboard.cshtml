@model BlindMatchPAS.Web.Models.Student.StudentDashboardViewModel

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Your Project Proposals</h1>
    <a asp-action="Create" class="btn btn-primary">Submit New Proposal</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Title</th>
                <th>Research Area</th>
                <th>Status</th>
                <th>Submitted On</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proposal in Model.Proposals)
            {
                <tr>
                    <td>@proposal.Title</td>
                    <td>@proposal.ResearchArea?.Name</td>
                    <td>
                        @{
                            var badgeClass = proposal.Status switch
                            {
                                BlindMatchPAS.Core.Entities.ProjectStatus.Pending => "bg-warning text-dark",
                                BlindMatchPAS.Core.Entities.ProjectStatus.UnderReview => "bg-info text-dark",
                                BlindMatchPAS.Core.Entities.ProjectStatus.Matched => "bg-success",
                                BlindMatchPAS.Core.Entities.ProjectStatus.Withdrawn => "bg-secondary",
                                _ => "bg-light text-dark"
                            };
                        }
                        <span class="badge @badgeClass">@proposal.Status</span>
                    </td>
                    <td>@proposal.CreatedAt.ToShortDateString()</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Details" asp-route-id="@proposal.Id" class="btn btn-outline-info">Details</a>
                            @if (proposal.Status == BlindMatchPAS.Core.Entities.ProjectStatus.Pending)
                            {
                                <a asp-action="Edit" asp-route-id="@proposal.Id" class="btn btn-outline-primary">Edit</a>
                                <form asp-action="Withdraw" asp-route-id="@proposal.Id" method="post" onsubmit="return confirm('Are you sure you want to withdraw this proposal?');">
                                    <button type="submit" class="btn btn-outline-danger">Withdraw</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Proposals.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">No proposals found. Start by submitting your first idea!</td>
                </tr>
            }
        </tbody>
    </table>
</div>
