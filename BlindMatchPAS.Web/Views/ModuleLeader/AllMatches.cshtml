@model BlindMatchPAS.Web.Models.ModuleLeader.AllMatchesViewModel

@{
    ViewData["Title"] = "Global Allocation Oversight";
}

<div class="row mb-5">
    <div class="col-md-12 text-center">
        <h1 class="display-4 fw-bold">Allocation <span class="text-primary">Oversight</span></h1>
        <p class="lead text-muted">A comprehensive view of all matched projects and supervisor-student pairings.</p>
    </div>
</div>

<div class="row row-cols-1 row-cols-lg-2 g-4">
    @foreach (var match in Model.Matches)
    {
        <div class="col">
            <div class="card h-100 border-0 shadow-sm overflow-hidden">
                <div class="row g-0 h-100">
                    <div class="col-1 bg-primary bg-opacity-75"></div>
                    <div class="col-11">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-light text-primary">ID: #@match.Id</span>
                                <span class="small text-muted"><i class="bi bi-calendar-check me-1"></i> @match.MatchedAt.ToString("MMM dd, yyyy")</span>
                            </div>
                            
                            <h5 class="fw-bold mb-4">@match.ProjectProposal?.Title</h5>
                            
                            <div class="row g-3">
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-3">
                                        <p class="small text-muted mb-1 fw-bold">STUDENT</p>
                                        <p class="mb-0 fw-bold">@match.Student?.FullName</p>
                                        <p class="small text-muted mb-0">@match.Student?.Email</p>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 border border-primary border-opacity-25 rounded-3">
                                        <p class="small text-primary mb-1 fw-bold">SUPERVISOR</p>
                                        <p class="mb-0 fw-bold">@match.Supervisor?.FullName</p>
                                        <p class="small text-muted mb-0">@match.Supervisor?.Email</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-4 pt-3 border-top d-flex justify-content-between align-items-center">
                                <span class="badge bg-info bg-opacity-10 text-info">@match.ProjectProposal?.ResearchArea?.Name</span>
                                <form asp-action="Reassign" asp-route-matchId="@match.Id" method="post" onsubmit="return confirm('WARNING: This will break the match and set the project back to Pending. Continue?')">
                                    <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none">
                                        <i class="bi bi-arrow-repeat me-1"></i> Break Match / Reassign
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Matches.Any())
{
    <div class="text-center py-5">
        <div class="display-1 text-muted mb-4 opacity-25"><i class="bi bi-people"></i></div>
        <h3>No matches found in the system</h3>
        <p class="text-muted">Wait for supervisors to express interest and confirm matches with students.</p>
    </div>
}
