@model BlindMatchPAS.Web.Models.ModuleLeader.ModuleLeaderDashboardViewModel

@{
    ViewData["Title"] = "Coordinator Dashboard";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1>Oversight Dashboard</h1>
        <p class="text-muted">Monitor the project allocation process and system health.</p>
    </div>
    <div class="col-md-4 text-md-end">
        <a asp-action="ResearchAreaManagement" class="btn btn-outline-primary">Manage Research Areas</a>
        <a asp-action="AllMatches" class="btn btn-primary">View All Matches</a>
    </div>
</div>

<div class="row mb-4">
    <div class="col">
        <div class="card shadow-sm border-0 bg-primary text-white text-center p-3">
            <h5 class="fw-light">Total Proposals</h5>
            <div class="display-6 fw-bold">@Model.TotalProposals</div>
        </div>
    </div>
    <div class="col">
        <div class="card shadow-sm border-0 bg-warning text-dark text-center p-3">
            <h5 class="fw-light">Pending Selection</h5>
            <div class="display-6 fw-bold">@Model.PendingProposals</div>
        </div>
    </div>
    <div class="col">
        <div class="card shadow-sm border-0 bg-success text-white text-center p-3">
            <h5 class="fw-light">Successful Matches</h5>
            <div class="display-6 fw-bold">@Model.MatchedProposals</div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h5 class="card-title mb-4">Latest Project Submissions</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Student</th>
                        <th>Research Area</th>
                        <th>Status</th>
                        <th>Submitted On</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proposal in Model.RecentProposals)
                    {
                        <tr>
                            <td>@proposal.Title</td>
                            <td>@proposal.Student?.FullName</td>
                            <td>@proposal.ResearchArea?.Name</td>
                            <td>
                                @{
                                    var badgeClass = proposal.Status switch
                                    {
                                        BlindMatchPAS.Core.Entities.ProjectStatus.Pending => "bg-warning text-dark",
                                        BlindMatchPAS.Core.Entities.ProjectStatus.Matched => "bg-success",
                                        _ => "bg-light text-dark"
                                    };
                                }
                                <span class="badge @badgeClass">@proposal.Status</span>
                            </td>
                            <td>@proposal.CreatedAt.ToShortDateString()</td>
                        </tr>
                    }
                    @if (!Model.RecentProposals.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No recent activity found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
