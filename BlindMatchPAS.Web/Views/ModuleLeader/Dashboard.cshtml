@model BlindMatchPAS.Web.Models.ModuleLeader.ModuleLeaderDashboardViewModel

@{
    ViewData["Title"] = "Coordinator Dashboard";
}

<div class="row mb-5 align-items-center">
    <div class="col-md-8">
        <h1 class="display-5 fw-bold text-gradient">Coordinator Dashboard</h1>
        <p class="text-muted">Monitor the project allocation process and system health.</p>
    </div>
    <div class="col-md-4 text-md-end">
        <div class="btn-group shadow-sm rounded-pill overflow-hidden">
            <a asp-action="ResearchAreaManagement" class="btn btn-outline-primary border-0 px-4">Research Areas</a>
            <a asp-action="AllMatches" class="btn btn-primary border-0 px-4">View All Matches</a>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 border-0 p-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle">
                        <i class="bi bi-file-earmark-text h4 mb-0"></i>
                    </div>
                    <span class="badge bg-light text-primary">Total</span>
                </div>
                <h2 class="display-6 fw-bold mb-0">@Model.TotalProposals</h2>
                <p class="text-muted small mb-0">Project Proposals</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 p-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-circle">
                        <i class="bi bi-hourglass-split h4 mb-0"></i>
                    </div>
                    <span class="badge bg-light text-warning">Waiting</span>
                </div>
                <h2 class="display-6 fw-bold mb-0">@Model.PendingProposals</h2>
                <p class="text-muted small mb-0">Pending Selection</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-0 p-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle">
                        <i class="bi bi-check2-circle h4 mb-0"></i>
                    </div>
                    <span class="badge bg-light text-success">Confirmed</span>
                </div>
                <h2 class="display-6 fw-bold mb-0">@Model.MatchedProposals</h2>
                <p class="text-muted small mb-0">Successful Matches</p>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-white py-3 border-0">
        <h5 class="fw-bold mb-0">Latest Project Submissions</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4">Title</th>
                    <th>Student</th>
                    <th>Research Area</th>
                    <th>Status</th>
                    <th class="pe-4">Submitted On</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var proposal in Model.RecentProposals)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@proposal.Title</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded-circle p-2 me-2 small">
                                    <i class="bi bi-person"></i>
                                </div>
                                <span>@proposal.Student?.FullName</span>
                            </div>
                        </td>
                        <td><span class="badge bg-light text-dark">@proposal.ResearchArea?.Name</span></td>
                        <td>
                            @{
                                var statusClass = proposal.Status switch
                                {
                                    BlindMatchPAS.Core.Entities.ProjectStatus.Pending => "status-pending",
                                    BlindMatchPAS.Core.Entities.ProjectStatus.Matched => "status-matched",
                                    _ => "bg-light text-dark"
                                };
                            }
                            <span class="badge @statusClass">@proposal.Status</span>
                        </td>
                        <td class="pe-4 text-muted small">@proposal.CreatedAt.ToShortDateString()</td>
                    </tr>
                }
                @if (!Model.RecentProposals.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                            No recent activity found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
