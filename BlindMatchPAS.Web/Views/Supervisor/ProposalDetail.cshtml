@model BlindMatchPAS.Core.Entities.ProjectProposal

@{
    ViewData["Title"] = "Proposal Details";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h2 class="mb-0">@Model.Title</h2>
                    <span class="badge bg-light text-primary border border-primary fs-6">@Model.ResearchArea?.Name</span>
                </div>
            </div>
            <div class="card-body p-4 border-top">
                <div class="alert alert-info border-0 shadow-sm mb-4">
                    <i class="bi bi-shield-lock-fill me-2"></i> <strong>Blind Selection Enabled:</strong> Student identity is hidden until you confirm this match.
                </div>

                <div class="row mb-4">
                    <div class="col-sm-3 text-muted">Abstract</div>
                    <div class="col-sm-9" style="white-space: pre-wrap;">@Model.Abstract</div>
                </div>

                <div class="row mb-4">
                    <div class="col-sm-3 text-muted">Technical Stack</div>
                    <div class="col-sm-9">
                        @foreach (var tech in Model.TechnicalStack.Split(','))
                        {
                            <span class="badge bg-light text-dark border me-1">@tech.Trim()</span>
                        }
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-sm-3 text-muted">Status</div>
                    <div class="col-sm-9">
                        @{
                            var statusClass = Model.Status == BlindMatchPAS.Core.Entities.ProjectStatus.UnderReview ? "text-info" : "text-warning";
                        }
                        <span class="fw-bold @statusClass">@Model.Status</span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-sm-3 text-muted">Submitted On</div>
                    <div class="col-sm-9">@Model.CreatedAt.ToString("D")</div>
                </div>
            </div>
            <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between">
                <a asp-action="BrowseProposals" class="btn btn-outline-secondary">Back to Browse</a>
                
                <div class="btn-group">
                    @if (Model.Status == BlindMatchPAS.Core.Entities.ProjectStatus.Pending)
                    {
                        <form asp-action="ExpressInterest" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-info me-2 text-white">Express Interest</button>
                        </form>
                    }
                    
                    @if (Model.Status == BlindMatchPAS.Core.Entities.ProjectStatus.Pending || Model.Status == BlindMatchPAS.Core.Entities.ProjectStatus.UnderReview)
                    {
                        <form asp-action="ConfirmMatch" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Confirming this match will reveal both your identity to the student and vice versa. Continue?');">
                            <button type="submit" class="btn btn-success">Confirm Match & Reveal Identity</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
