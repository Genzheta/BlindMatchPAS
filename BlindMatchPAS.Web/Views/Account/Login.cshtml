@model BlindMatchPAS.Web.Models.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card p-4">
            <div class="card-body text-center">
                <div class="mb-4">
                    <i class="bi bi-shield-lock text-primary display-4"></i>
                </div>
                <h2 class="mb-3">Welcome Back</h2>
                <p class="text-muted mb-4">Login to access your BlindMatch PAS dashboard</p>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="form-floating mb-3 text-start">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" required />
                        <label asp-for="Email">Email Address</label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    
                    <div class="form-floating mb-3 text-start">
                        <input asp-for="Password" class="form-control" type="password" placeholder="Password" required />
                        <label asp-for="Password">Password</label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-check text-start mb-4">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 mb-3">
                        Sign In <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>

                <p class="mb-0">
                    Don't have an account? <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Register Now</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
